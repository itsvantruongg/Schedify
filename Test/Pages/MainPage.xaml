<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Test.Views"
             x:Class="Test.Pages.MainPage"
             BackgroundColor="#ECF0F1">

    <Grid>
        <Frame BackgroundColor="#f5f3ee"
               BorderColor="Transparent"/>
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="0">
            <!-- ── MENU OVERLAY ── -->
            <Grid x:Name="MenuOverlay"
                Grid.RowSpan="5"  
                IsVisible="{Binding IsMenuVisible}"
                ZIndex="99"
                Margin="0,0,0,0">
                <BoxView BackgroundColor="#80000000"
                         HorizontalOptions="Fill"
                         VerticalOptions="Fill">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseMenuCommand}"/>
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Frame BackgroundColor="White" CornerRadius="0" Padding="20"
                   HorizontalOptions="End" VerticalOptions="Fill"
                   WidthRequest="260" HasShadow="True" BorderColor="Transparent">
                    <Grid RowDefinitions="*,auto">
                        <VerticalStackLayout Spacing="16" VerticalOptions="Start" Margin="0,40,0,0">
                            <!-- Avatar -->
                            <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="8">
                                <Frame WidthRequest="70" HeightRequest="70" CornerRadius="35"
                               BackgroundColor="#512BD4" Padding="0"
                               HorizontalOptions="Center" HasShadow="False"
                               BorderColor="Transparent">
                                    <Label Text="{Binding AvatarLetter}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                                </Frame>
                                <Label Text="{Binding Username}"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#333" HorizontalOptions="Center"/>
                                <Label Text="{Binding Email}" 
                               FontSize="12" TextColor="Gray"
                               HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                            <!-- View mode buttons -->
                            <Label Text="Chế độ xem" FontSize="13"
                                    TextColor="Gray" Margin="0,0,0,-8"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button x:Name="BtnMonthView"
                                Grid.Column="0" Text="📅 Tháng" 
                                BackgroundColor="#3498DB" TextColor="White"
                                CornerRadius="8" FontSize="13" HeightRequest="42"
                                Clicked="OnMonthViewClicked"/>
                                <Button x:Name="BtnWeekView"
                                Grid.Column="1" Text="📆 Tuần" 
                                BackgroundColor="#ECF0F1" TextColor="#2C3E50"
                                CornerRadius="8" FontSize="13" HeightRequest="42"
                                BorderColor="#BDC3C7" BorderWidth="1"
                                Clicked="OnWeekViewClicked"/>
                            </Grid>

                            <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                            <Label Text="Chức năng chính" FontSize="13" 
                           TextColor="Gray" Margin="0,0,0,-8"/>
                            <Grid RowDefinitions="*,*,*"
                                    ColumnSpacing="0" Margin="5">
                                <Button Grid.Row="0" Text="Tải Web 🌐" 
                                BackgroundColor="#3498DB" TextColor="White"
                                FontAttributes="Bold" FontSize="13"
                                CornerRadius="10" Margin="5"
                                Clicked="OnLoadWebClicked"/>
                                <Button Grid.Row="1" Text="Cache 📂"
                                BackgroundColor="#9B59B6" TextColor="White"
                                FontAttributes="Bold" FontSize="13"
                                CornerRadius="10" Margin="5"
                                Command="{Binding SyncFromServerCommand}"/>
                                <Button Grid.Row="2" Text="Xóa 🗑️"
                                BackgroundColor="#95A5A6" TextColor="White"
                                FontAttributes="Bold" FontSize="13"
                                CornerRadius="10" Margin="5"
                                Command="{Binding ClearCommand}"/>
                            </Grid>

                            <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                            <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <Button Grid.Row="1"
                                Text="Đăng xuất"
                                ImageSource="logout.svg"
                                Command="{Binding LogoutCommand}"
                                IsEnabled="{Binding IsNotBusy}"
                                BackgroundColor="#ffcfcf" TextColor="#ad0000"
                                CornerRadius="25"  HeightRequest="48"/>
                    </Grid>
                </Frame>
            </Grid>

            <!-- ── WEBVIEW OVERLAY ── -->
            <Grid x:Name="WebViewContainer"
              Grid.RowSpan="5"
              IsVisible="False"
              BackgroundColor="#80000000"
              ZIndex="100">
                <Frame BackgroundColor="White" CornerRadius="15" Padding="0"
                   Margin="20" HasShadow="True"
                   VerticalOptions="Fill" HorizontalOptions="Fill">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Frame Grid.Row="0" BackgroundColor="#3498DB"
                           CornerRadius="0" Padding="15" HasShadow="False">
                            <Label Text="🌐 Đăng nhập HAU" 
                               FontSize="18" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center"/>
                        </Frame>
                        <WebView x:Name="LoginWebView" Grid.Row="1"
                             Navigated="OnWebViewNavigated"
                             Navigating="OnWebViewNavigating"/>
                        <ActivityIndicator x:Name="LoadingIndicator"
                                       Grid.Row="1" IsRunning="False" IsVisible="False"
                                       Color="#3498DB" VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       HeightRequest="50" WidthRequest="50"/>
                        <Frame Grid.Row="2" BackgroundColor="#ECF0F1"
                           CornerRadius="0" Padding="15,10" HasShadow="False">
                            <Button Text="✕ Hủy" BackgroundColor="#E74C3C" TextColor="White"
                                    FontAttributes="Bold" CornerRadius="8" HeightRequest="45"
                                    Clicked="OnCancelLoginClicked"/>
                        </Frame>
                    </Grid>
                </Frame>
            </Grid>

            <!-- ── ROW 0: TOOLBAR ── -->
            <Frame Grid.Row="0"
                   Padding="0"
                   Margin="0"
                   BackgroundColor="Transparent"
                   BorderColor="Transparent">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="0" Margin="5,5,0,0">
                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="0"
                                         HorizontalOptions="Start"
                                         VerticalOptions="Center"
                                         Margin="10,0,0,0">
                        <Grid ColumnDefinitions="50,*">
                            <Label Grid.Column="0"
                                   Text="Chào"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   Margin="0,-5,0,0"
                                   TextColor="#2C3E50"/>
                            <Label Grid.Column="1"
                                   Text="{Binding Username}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   Margin="0,-5,0,0"
                                   TextColor="#2C3E50"/>
                        </Grid>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" 
                            Text="☰" 
                            BackgroundColor="Transparent" 
                            TextColor="Black"
                            FontSize="30"
                            Padding="0"
                            HeightRequest="40"
                            WidthRequest="40"
                            Command="{Binding OpenMenuCommand}"/>
                </Grid>
            </Frame>

            <!-- ── ROW 1: NAVIGATION ── -->
            <Grid Grid.Row="1" RowDefinitions="Auto,Auto"
              x:Name="NavBarRow">
                <Frame Grid.Row="0" BackgroundColor="Transparent" BorderColor="Transparent"
                        CornerRadius="8" Padding="0" Margin="15,0,10,10" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                        <!-- Nút ◀ -->
                        <Border Grid.Row="0"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                WidthRequest="40"
                                HeightRequest="40"
                                Margin="0,0,8,0"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#20000000" Offset="3,3" Radius="4"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPreviousClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="‹"
                                   FontSize="25"
                                   FontAttributes="Bold"
                                   TextColor="#1A2B4A"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center">
                            </Label>
                        </Border>
                        <DatePicker x:Name="PeriodBtn"
                                    Grid.Column="1"
                                    MinimumDate="2020-01-01"
                                    MaximumDate="2030-12-31"
                                    Format="'Tháng' M'/' yyyy"
                                    FontSize="18"
                                    Margin="10,0,10,0"
                                    FontAttributes="Bold"
                                    TextColor="#2C3E50"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    DateSelected="OnCalendarPickerDateSelected"/>
                        <!-- Nút ★ -->
                        <Border Grid.Column="2"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                WidthRequest="40"
                                HeightRequest="40"
                                Margin="0,0,0,0"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#20000000" Offset="3,3" Radius="4"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTodayClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="★"
                                   FontSize="25"
                                   FontAttributes="Bold"
                                   TextColor="#3498DB"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center">
                            </Label>
                        </Border>
                        <!-- Nút ▶ -->
                        <Border Grid.Column="3"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                WidthRequest="40"
                                HeightRequest="40"
                                Margin="0,0,8,0"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#20000000" Offset="3,3" Radius="4"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNextClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="›"
                                   FontSize="25"
                                   FontAttributes="Bold"
                                   TextColor="#1A2B4A"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center">
                            </Label>
                        </Border>
                    </Grid>

                </Frame>
            </Grid>

            <!-- ── ROW 2+3: CALENDAR + LOG / WEEK VIEW ── -->

            <!-- Month View: calendar grid (Row 2) -->
            <Grid Grid.Row="2" x:Name="MonthCalendarContainer" Padding="10,0,10,5">
                <Frame BackgroundColor="Transparent" BorderColor="Transparent"
                   CornerRadius="8" Padding="0" HasShadow="False">
                    <Grid x:Name="CalendarGrid"
                          RowDefinitions="40,*,*,*,*,*,*"
                          ColumnDefinitions="*,*,*,*,*,*,*">
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                BackgroundColor="#a4c6e1"
                                Margin="1"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Grid.Row="0" Grid.Column="0" Text="T2" BackgroundColor="#a0c5e3" TextColor="Black" FontAttributes="Bold" FontSize="13" HorizontalOptions="Fill" VerticalOptions="Fill" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="1"/>
                        </Border>
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                BackgroundColor="#a4c6e1"
                                Margin="1"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Grid.Row="0" Grid.Column="1" Text="T3" BackgroundColor="#a0c5e3" TextColor="Black" FontAttributes="Bold" FontSize="13"   HorizontalOptions="Fill" VerticalOptions="Fill" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="1"/>
                        </Border>
                        <Border Grid.Row="0"
                                Grid.Column="2"
                                BackgroundColor="#a4c6e1"
                                Margin="1"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Grid.Row="0" Grid.Column="1" Text="T4" BackgroundColor="#a0c5e3" TextColor="Black" FontAttributes="Bold" FontSize="13"  HorizontalOptions="Fill" VerticalOptions="Fill" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="1"/>
                        </Border>
                        <Border Grid.Row="0"
                                Grid.Column="3"
                                BackgroundColor="#a4c6e1"
                                Margin="1"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Grid.Row="0" Grid.Column="1" Text="T5" BackgroundColor="#a0c5e3" TextColor="Black" FontAttributes="Bold" FontSize="13"  HorizontalOptions="Fill" VerticalOptions="Fill" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="1"/>
                        </Border>
                        <Border Grid.Row="0"
                                Grid.Column="4"
                                BackgroundColor="#a4c6e1"
                                Margin="1"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Grid.Row="0" Grid.Column="1" Text="T6" BackgroundColor="#a0c5e3" TextColor="Black" FontAttributes="Bold" FontSize="13" HorizontalOptions="Fill" VerticalOptions="Fill" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="1"/>
                        </Border>
                        <Border Grid.Row="0"
                                Grid.Column="5"
                                BackgroundColor="#a4c6e1"
                                Margin="1"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Grid.Row="0" Grid.Column="1" Text="T7" BackgroundColor="#a0c5e3" TextColor="Black" FontAttributes="Bold" FontSize="13"  HorizontalOptions="Fill" VerticalOptions="Fill" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="1"/>
                        </Border>
                        <Border Grid.Row="0"
                                Grid.Column="6"
                                BackgroundColor="#a4c6e1"
                                Margin="1"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Grid.Row="0" Grid.Column="1" Text="CN" BackgroundColor="#a0c5e3" TextColor="Black" FontAttributes="Bold" FontSize="13"  HorizontalOptions="Fill" VerticalOptions="Fill" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="1"/>
                        </Border>
                        <Grid.GestureRecognizers>
                            <SwipeGestureRecognizer Direction="Left"  Swiped="OnCalendarSwipedLeft"/>
                            <SwipeGestureRecognizer Direction="Right" Swiped="OnCalendarSwipedRight"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Frame>
            </Grid>

            <!-- Thay dòng WeekView hiện tại -->
            <views:WeekView x:Name="WeekViewControl"
                            Grid.Row="2" Grid.RowSpan="2"
                            IsVisible="False"
                            BackgroundColor="Transparent"/>

            <!-- ── ROW 3: TODAY PANEL ── -->
            <Frame x:Name="LogPanel" Grid.Row="3"
                   BackgroundColor="Transparent"
                   CornerRadius="0" Margin="10,5,10,0"
                   Padding="0" HasShadow="False"
                   BorderColor="Transparent"
                   VerticalOptions="Fill">
                <Grid RowDefinitions="Auto,*">

                    <!-- Header: Today + View all -->
                    <Grid Grid.Row="0" Margin="4,0,4,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   x:Name="LblPanelTitle"
                                   Text="Hôm nay"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#2C3E50"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="View all"
                                   FontSize="15"
                                   TextColor="#3498DB"
                                   VerticalOptions="Center"
                                   x:Name="lblViewAll">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnViewAllClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Grid>

                    <!-- Danh sách event hôm nay -->
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout x:Name="TodayEventStack"
                                             Spacing="10"
                                             Padding="0,0,0,10"/>
                    </ScrollView>
                </Grid>
            </Frame>

            <!-- ── ROW 4: Decripition ── -->
            <Frame Grid.Row="4" BackgroundColor="Transparent" CornerRadius="0"
               Padding="0,8" Margin="0" HasShadow="False" BorderColor="Transparent"
               x:Name="LegendRow">
                <Label Text="🟢 Học  |  🟡 Thi  |  🔴 Cả hai  |  ⭐ Hôm nay"
                   FontSize="12" TextColor="Black"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            </Frame>

        </Grid>
    </Grid>
</ContentPage>