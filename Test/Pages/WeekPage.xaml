<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Test.Views.WeekView">
    <Grid RowDefinitions="Auto,Auto,*"
          BackgroundColor="Transparent">

        <!-- Navigation bar -->
        <Grid ColumnDefinitions="*,Auto,Auto,Auto"
              Padding="16,10,16,6"
              BackgroundColor="Transparent">

            <!-- Tháng/Năm + DatePicker ẩn phía sau -->
            <Grid Grid.Column="0"
                  HorizontalOptions="Start"
                  VerticalOptions="Center">
                <DatePicker x:Name="WeekDatePicker"
                            MinimumDate="2020-01-01"
                            MaximumDate="2030-12-31"
                            Format="'Tháng' M'/' yyyy"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#1A2B4A"
                            BackgroundColor="Transparent"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            Opacity="0.01"
                            HeightRequest="40"
                            DateSelected="OnWeekDatePickerSelected"/>
                <VerticalStackLayout Spacing="0" InputTransparent="True"
                         VerticalOptions="Center">
                    <!-- Label hiển thị đè lên DatePicker -->
                    <Label x:Name="WeekMonthLabel"
                           Text="Tháng 3/ 2026"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1A2B4A"
                           VerticalOptions="Center"
                           HorizontalOptions="Start"
                           InputTransparent="True"/>
                    <Label x:Name="WeekSubLabel"
                           Text=""
                           FontSize="12"
                           TextColor="#5f6368"
                           VerticalOptions="End"
                           HorizontalOptions="Start"
                           Margin="2,0,0,2"
                           InputTransparent="True"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Nút Today ★ -->
            <Border Grid.Column="1"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    Margin="0,0,8,0"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="4"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTodayClicked"/>
                </Border.GestureRecognizers>
                <Label Text="★"
                       FontSize="18"
                       TextColor="#3498DB"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       InputTransparent="True"/>
            </Border>

            <!-- Nút ◀ -->
            <Border Grid.Column="2"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    Margin="0,0,8,0"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="4"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPreviousWeekClicked"/>
                </Border.GestureRecognizers>
                <Label Text="‹"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1A2B4A"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                </Label>
            </Border>

            <!-- Nút ▶ -->
            <Border Grid.Column="3"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,2" Radius="4"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNextWeekClicked"/>
                </Border.GestureRecognizers>
                <Label Text="›"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1A2B4A"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center">
                </Label>
            </Border>
        </Grid>

        <!-- Header 7 ngày cố định — bấm vào ngày để xem ngày đó -->
        <Grid x:Name="WeekHeaderGrid"
              Grid.Row="1"
              ColumnDefinitions="*,*,*,*,*,*,*"
              HeightRequest="60"
              BackgroundColor="Transparent"
              Margin="0"/>

        <!-- Body scroll: cột giờ + nội dung ngày được chọn -->
        <Frame Grid.Row="2"
               BackgroundColor="Transparent"
               BorderColor="Transparent"
               Padding="0" CornerRadius="0"
               HasShadow="False">
            <ScrollView x:Name="WeekScrollView" Orientation="Vertical" BackgroundColor="Transparent">
                <Grid x:Name="WeekBodyGrid"
                      ColumnDefinitions="45,*"/>
            </ScrollView>
        </Frame>

    </Grid>
</ContentView>